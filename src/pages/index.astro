---
import Base from '../layouts/Base.astro';
import { bands, eras } from '../data/bands.js';

const featured = ['pacitan', 'babe'].map((s) => bands.find((b) => b.slug === s)).filter(Boolean);
const initials = (name) => name.replace(/[^A-Za-z ]/g, '').split(' ').filter(Boolean).slice(0, 2).map((w) => w[0]).join('').toUpperCase() || '?';
---
<Base title="Pacitan Raw — Ruang Bawah Tanah Pacitan">
  <!-- TOP : logo + tagline -->
  <header class="top">
    <div class="wrap">
      <img class="logo" src="/img/logo-white.webp" alt="Pacitan Raw" />
      <div class="tag">Ruang Bawah Tanah Pacitan</div>
      <div class="cta-row" style="justify-content:center;">
        <a href="/kolektif" class="btn primary">Jelajahi Kolektif</a>
        <a href="/rilis" class="btn">Dengar Rilisan</a>
      </div>
    </div>
  </header>

  <!-- AKAR SKENA : Pacitan & BABE -->
  <section class="section">
    <div class="wrap">
      <div class="section-head">
        <h2>Akar Skena</h2>
        <span class="muted">tempat &amp; kolektif yang memulai semuanya</span>
      </div>
      <div class="feat-grid">
        {featured.map((b) => (
          <a class="feat" href={`/band/${b.slug}/`}>
            {b.cover
              ? <div class="feat-img"><img src={b.cover} alt={b.name} loading="lazy" referrerpolicy="no-referrer" /></div>
              : <div class="feat-img ph"><span>{initials(b.name)}</span></div>}
            <div class="feat-body">
              <span class="kicker">{b.typeLabel}</span>
              <h3>{b.name}</h3>
              <p>{b.tagline}</p>
              <span class="feat-link">Selengkapnya &rarr;</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- TENTANG : sejarah skena -->
  <section id="tentang" class="section">
    <div class="wrap">
      <div class="section-head">
        <h2>Tentang</h2>
        <p class="muted" style="max-width:46ch;">
          Pacitan Raw merilis &amp; mewadahi musik bawah tanah Pacitan — dari punk &amp;
          hardcore generasi awal sampai noise &amp; hip-hop yang aktif hari ini.
        </p>
      </div>
      <div class="eras">
        {eras.map((e, i) => (
          <div class="era">
            <div class="no">0{i + 1}</div>
            <h3>{e.label}</h3>
            <div class="sub">{e.sub}</div>
            <p>{e.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</Base>
